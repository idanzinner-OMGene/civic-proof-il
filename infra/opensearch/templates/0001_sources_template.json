{
  "index_patterns": ["source_documents*", "evidence_spans*", "claim_cache*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "analysis": {
        "analyzer": {
          "default": {
            "type": "standard"
          }
        }
      }
    },
    "mappings": {
      "dynamic": "true",
      "properties": {
        "captured_at": {"type": "date"},
        "source_tier": {"type": "integer"},
        "url": {"type": "keyword"},
        "archive_uri": {"type": "keyword"},
        "text": {"type": "text"}
      }
    }
  },
  "priority": 100,
  "_meta": {
    "phase": "0",
    "note": "Placeholder template; full mappings land in Phase 1."
  }
}
