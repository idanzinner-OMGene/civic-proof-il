{
  "index_patterns": ["evidence_spans*"],
  "priority": 110,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.knn": true,
      "analysis": {
        "analyzer": {
          "text_he": {
            "type": "standard"
          },
          "normalized_he": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": ["lowercase"]
          }
        }
      }
    },
    "mappings": {
      "dynamic": "strict",
      "properties": {
        "span_id": {"type": "keyword"},
        "document_id": {"type": "keyword"},
        "source_tier": {"type": "integer"},
        "source_type": {"type": "keyword"},
        "url": {"type": "keyword"},
        "archive_uri": {"type": "keyword"},
        "text": {
          "type": "text",
          "analyzer": "text_he",
          "fields": {
            "keyword": {"type": "keyword", "ignore_above": 512}
          }
        },
        "normalized_text": {
          "type": "text",
          "analyzer": "normalized_he"
        },
        "embedding": {
          "type": "knn_vector",
          "dimension": 384,
          "method": {
            "name": "hnsw",
            "space_type": "cosinesimil",
            "engine": "lucene"
          }
        },
        "char_start": {"type": "integer"},
        "char_end": {"type": "integer"},
        "captured_at": {"type": "date"}
      }
    }
  },
  "_meta": {
    "phase": "3",
    "note": "Phase-3: added normalized_text + knn_vector embedding (dim=384). Vector search is OFF by default; enabled via CIVIC_RETRIEVAL_VECTOR=1 once an embedding model is approved.",
    "analyzer_todo": "text_he still aliases to `standard`. Swap for a real Hebrew analyzer in Phase 6. dynamic=strict — new fields require a template bump."
  }
}
