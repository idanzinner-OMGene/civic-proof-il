# civic-proof-il — shared environment variable contract
# Copy this file to `.env` before running `make up`.
# Never commit real secrets; values below are safe dev defaults only.

# Runtime environment
ENV=dev

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=civic
POSTGRES_PASSWORD=civic_dev_pw
POSTGRES_DB=civic

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=civic_dev_pw

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# MinIO (S3-compatible object store for archived source material)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_ARCHIVE=civic-archive

# API
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Reviewer UI — HTTP Basic Auth
# REVIEWER_UI_USER defaults to "reviewer" if unset.
# REVIEWER_UI_PASSWORD must be set; the UI returns 503 if it is missing.
REVIEWER_UI_USER=reviewer
REVIEWER_UI_PASSWORD=change_me_in_production
