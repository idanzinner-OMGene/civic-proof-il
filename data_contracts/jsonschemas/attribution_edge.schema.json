{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://civic-proof-il.org/schemas/attribution_edge.schema.json",
  "title": "AttributionEdge",
  "description": "Persists the judgment connecting a Declaration to a formal record or claim. Relation type is the outcome of Stage B verification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attribution_id",
    "from_declaration_id",
    "to_object_id",
    "to_object_type",
    "relation_type",
    "evidence_span_ids",
    "confidence_band",
    "review_status",
    "created_at"
  ],
  "properties": {
    "attribution_id": {"type": "string", "format": "uuid"},
    "from_declaration_id": {"type": "string", "format": "uuid"},
    "to_object_id": {"type": "string", "format": "uuid"},
    "to_object_type": {
      "type": "string",
      "enum": [
        "VoteEvent",
        "Bill",
        "PositionTerm",
        "GovernmentDecision",
        "ElectionResult",
        "AtomicClaim"
      ]
    },
    "relation_type": {
      "type": "string",
      "enum": [
        "supported_by",
        "contradicted_by",
        "overstates",
        "underspecifies",
        "time_scope_mismatch",
        "entity_ambiguous",
        "not_checkable_against_record"
      ]
    },
    "evidence_span_ids": {
      "type": "array",
      "items": {"type": "string", "format": "uuid"}
    },
    "confidence_band": {
      "type": "string",
      "enum": ["high", "medium", "low", "uncertain"]
    },
    "review_status": {
      "type": "string",
      "enum": ["pending", "confirmed", "rejected", "needs_human_review"]
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
