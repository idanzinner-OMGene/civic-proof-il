{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://civic-proof-il.org/schemas/position_term.schema.json",
  "title": "PositionTerm",
  "description": "Time-bounded role holding. A person occupies an office from valid_from to valid_to. Used for date-aware verification of office claims.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "position_term_id",
    "person_id",
    "office_id",
    "appointing_body",
    "valid_from",
    "valid_to",
    "is_acting",
    "source_document_id",
    "created_at"
  ],
  "properties": {
    "position_term_id": {"type": "string", "format": "uuid"},
    "person_id": {"type": "string", "format": "uuid"},
    "office_id": {"type": "string", "format": "uuid"},
    "appointing_body": {"type": ["string", "null"]},
    "valid_from": {"type": ["string", "null"], "format": "date-time"},
    "valid_to": {"type": ["string", "null"], "format": "date-time"},
    "is_acting": {"type": "boolean"},
    "source_document_id": {"type": ["string", "null"], "format": "uuid"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
